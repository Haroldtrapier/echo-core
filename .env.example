# ── Echo Core environment ─────────────────────────────────────────────────────
# Copy to .env for local dev. NONE of these are required to build/test: missing
# keys degrade providers to safe/mock/dry-run behavior. Never commit real secrets.

# Core
APP_NAME=Echo Core
ENV=development

# Database — Railway/Supabase inject DATABASE_URL automatically in prod.
# Local/test defaults to a throwaway SQLite file when unset.
DATABASE_URL=sqlite:///./echo.db

# API auth — required in production. When unset, auth is DISABLED (dev only).
# Send as header:  x-echo-key: <value>   or   Authorization: Bearer <value>
ECHO_API_KEY=

# AI (Anthropic) — when unset, AI generators return safe placeholder drafts.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Feature flags
ECHO_ENABLED=true
# Hard kill-switch: everything stays dry-run until this is explicitly true.
ECHO_ALLOW_LIVE_PUBLISH=false

# Tenancy — default workspace when a caller does not supply tenant_id.
DEFAULT_TENANT_ID=imani-internal

# ── Sturgeon handoff ──────────────────────────────────────────────────────────
# When STURGEON_API_URL is set, approved GovCon opportunities are POSTed to
# Sturgeon's intake endpoint. When unset, handoffs are stored locally (pending)
# for Sturgeon to pull — no network call, so local build/test never needs it.
STURGEON_API_URL=
STURGEON_API_KEY=
STURGEON_APP_URL=https://sturgeon.ai

# ── GovCon data providers (all optional; missing key = no live signals) ───────
SAM_GOV_API_KEY=
GOVCON_CMS_URL=
GOVCON_CMS_API_KEY=

# ── Publishing / social connectors (optional; live publish gated separately) ──
BUFFER_API_KEY=
BUFFER_PROFILE_IDS=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
SLACK_WEBHOOK_URL=

# ── Analytics attribution (optional) ──────────────────────────────────────────
GA4_PROPERTY_ID=
GA4_ACCESS_TOKEN=

# ── Media generation + storage (optional) ─────────────────────────────────────
IMAGE_API_KEY=
IMAGE_API_BASE=https://api.openai.com/v1
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1024x1024
VIDEO_API_KEY=
VIDEO_API_URL=
VIDEO_VOICE=default
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
MEDIA_BUCKET=echo-media

# ── Scheduler (Phase 2 — OFF by default) ──────────────────────────────────────
# Master switch for recurring workflow schedules (daily brief, weekly tracker).
# Stays false in production until you deliberately enable automation.
ECHO_SCHEDULER_ENABLED=false

# ── GA4 conversion tracking (Phase 2 — Measurement Protocol, optional) ────────
# No-op unless BOTH are set. Distinct from the read-only GA4_ACCESS_TOKEN above.
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# ── Disaster procurement adapters (Phase 2 — NRS / SEMA, optional) ────────────
# Disabled unless a URL is set. *_USE_MOCK=true emits labelled mock signals for
# demo/dev only — never enable mock in production.
NRS_API_URL=
NRS_API_KEY=
NRS_USE_MOCK=false
SEMA_API_URL=
SEMA_API_KEY=
SEMA_USE_MOCK=false

# ── Worker / CORS ─────────────────────────────────────────────────────────────
WORKER_TICK_INTERVAL=60
CORS_ORIGINS=*
